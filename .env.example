# Tududi Dev Service Configuration
NODE_ENV=development
TUDUDI_PORT=3000
TUDUDI_LOG_LEVEL=info

# Tududi API Configuration
TUDUDI_API_URL=http://tududi:3000

# Authentication - Choose one method
# Option 1: API Key (recommended)
TUDUDI_API_KEY=your-api-key-here

# Option 2: Email and Password (legacy)
# TUDUDI_EMAIL=your-email@example.com
# TUDUDI_PASSWORD=your-password

# MCP Server Configuration
HTTP_PORT=8080
LOG_LEVEL=info
